{
  "version": 2,
  "buildCommand": "",
  "installCommand": "",
  "framework": null,
  "crons": [
    { "path": "/api/daily-note", "schedule": "0 0 * * *" }
  ],
  "rewrites": [
    { "source": "/api/daily-note", "destination": "/api/daily-note" },
    { "source": "/api/(.*)", "destination": "/api/chat" },
    { "source": "/", "destination": "/mobile-chat.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
